import { NextRequest } from 'next/server';
import { prisma } from '@/lib/prisma';
import {
  successResponse,
  paginatedResponse,
  errorResponse,
  validationErrorResponse,
  extractZodErrors,
  notFoundResponse,
} from '@/lib/api-response';
import { z } from 'zod';

/**
 * 发货管理 API
 * 管理出库单的发货信息
 */

// 创建发货信息 Schema
const CreateShipmentSchema = z.object({
  outboundOrderId: z.string().min(1, '出库单 ID 不能为空'),
  logisticsCompany: z.string().optional(),
  trackingNo: z.string().optional(),
  deliveryAddress: z.string().optional(),
  receiverName: z.string().optional(),
  receiverPhone: z.string().optional(),
  packages: z.number().int().positive().optional(),
  grossWeight: z.number().positive().optional(),
  volume: z.number().positive().optional(),
  shippingCost: z.number().min(0).optional(),
  notes: z.string().optional(),
});

// 更新发货信息 Schema（部分字段）
const UpdateShipmentSchema = CreateShipmentSchema.partial();

// 查询参数 Schema
const QuerySchema = z.object({
  page: z.coerce.number().min(1).default(1),
  limit: z.coerce.number().min(1).max(100).default(20),
  status: z.enum(['DRAFT', 'PENDING', 'SHIPPED', 'CANCELLED']).optional(),
  search: z.string().optional(), // 搜索物流单号、收货人等
  sortBy: z.string().default('createdAt'),
  sortOrder: z.enum(['asc', 'desc']).default('desc'),
});

/**
 * GET /api/v1/shipments
 * 获取发货列表
 */
export async function GET(request: NextRequest) {
  try {
    const searchParams = request.nextUrl.searchParams;
    const queryResult = QuerySchema.safeParse(Object.fromEntries(searchParams));

    if (!queryResult.success) {
      return validationErrorResponse(extractZodErrors(queryResult.error));
    }

    const { page, limit, status, search, sortBy, sortOrder } = queryResult.data;

    // 构建查询条件
    const where: any = {};

    if (status) {
      where.outboundOrder = {
        status,
      };
    }

    if (search) {
      where.OR = [
        { trackingNo: { contains: search } },
        { receiverName: { contains: search } },
        { logisticsCompany: { contains: search } },
      ];
    }

    // 查询总数
    const total = await prisma.shipmentOutbound.count({ where });

    // 查询数据
    const shipments = await prisma.shipmentOutbound.findMany({
      where,
      include: {
        outboundOrder: {
          include: {
            items: {
              include: {
                product: {
                  select: {
                    id: true,
                    name: true,
                    sku: true,
                  },
                },
              },
            },
          },
        },
      },
      skip: (page - 1) * limit,
      take: limit,
      orderBy: {
        [sortBy]: sortOrder,
      },
    });

    return paginatedResponse(
      shipments,
      {
        page,
        limit,
        total,
        totalPages: Math.ceil(total / limit),
      },
      'SUCCESS'
    );
  } catch (error) {
    console.error('Error fetching shipments:', error);
    return errorResponse('获取发货列表失败');
  }
}

/**
 * POST /api/v1/shipments
 * 创建或更新发货信息
 */
export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const validationResult = CreateShipmentSchema.safeParse(body);

    if (!validationResult.success) {
      return validationErrorResponse(extractZodErrors(validationResult.error));
    }

    const data = validationResult.data;

    // 检查出库单是否存在
    const outboundOrder = await prisma.outboundOrder.findUnique({
      where: { id: data.outboundOrderId },
      include: { shipment: true },
    });

    if (!outboundOrder) {
      return notFoundResponse('出库单');
    }

    // 检查出库单状态
    if (outboundOrder.status === 'CANCELLED') {
      return conflictResponse('已取消的出库单无法创建发货信息');
    }

    // 创建或更新发货信息
    const shipment = await prisma.$transaction(async (tx) => {
      if (outboundOrder.shipment) {
        // 更新现有发货信息
        return await tx.shipmentOutbound.update({
          where: { id: outboundOrder.shipment.id },
          data: {
            logisticsCompany: data.logisticsCompany,
            trackingNo: data.trackingNo,
            deliveryAddress: data.deliveryAddress,
            receiverName: data.receiverName,
            receiverPhone: data.receiverPhone,
            packages: data.packages,
            grossWeight: data.grossWeight,
            volume: data.volume,
            shippingCost: data.shippingCost,
            notes: data.notes,
          },
          include: {
            outboundOrder: {
              include: {
                items: {
                  include: {
                    product: true,
                  },
                },
              },
            },
          },
        });
      } else {
        // 创建新的发货信息
        return await tx.shipmentOutbound.create({
          data: {
            outboundOrderId: data.outboundOrderId,
            logisticsCompany: data.logisticsCompany,
            trackingNo: data.trackingNo,
            deliveryAddress: data.deliveryAddress,
            receiverName: data.receiverName,
            receiverPhone: data.receiverPhone,
            packages: data.packages,
            grossWeight: data.grossWeight,
            volume: data.volume,
            shippingCost: data.shippingCost,
            notes: data.notes,
          },
          include: {
            outboundOrder: {
              include: {
                items: {
                  include: {
                    product: true,
                  },
                },
              },
            },
          },
        });
      }
    });

    return successResponse(shipment, '发货信息保存成功');
  } catch (error) {
    console.error('Error creating/updating shipment:', error);
    return errorResponse('保存发货信息失败');
  }
}

/**
 * PUT /api/v1/shipments/[id]
 * 更新发货信息并确认发货
 */
export async function PUT(request: NextRequest) {
  try {
    const body = await request.json();
    const { shipmentId, shippedAt, ...data } = body;

    if (!shipmentId) {
      return validationErrorResponse([{ field: 'shipmentId', message: '发货 ID 不能为空' }]);
    }

    // 检查发货信息是否存在
    const existingShipment = await prisma.shipmentOutbound.findUnique({
      where: { id: shipmentId },
    });

    if (!existingShipment) {
      return notFoundResponse('发货信息');
    }

    // 更新发货信息
    const shipment = await prisma.$transaction(async (tx) => {
      const updateData: any = { ...data };

      // 如果提供了发货时间，设置为已发货
      if (shippedAt) {
        updateData.shippedAt = new Date(shippedAt);
      }

      const updated = await tx.shipmentOutbound.update({
        where: { id: shipmentId },
        data: updateData,
        include: {
          outboundOrder: {
            include: {
              items: {
                include: {
                  product: true,
                },
              },
            },
          },
        },
      });

      // 如果设置了发货时间，更新出库单状态为已发货
      if (shippedAt && existingShipment.outboundOrderId) {
        await tx.outboundOrder.update({
          where: { id: existingShipment.outboundOrderId },
          data: { status: 'SHIPPED' },
        });
      }

      return updated;
    });

    return successResponse(shipment, '发货信息更新成功');
  } catch (error) {
    console.error('Error updating shipment:', error);
    return errorResponse('更新发货信息失败');
  }
}
