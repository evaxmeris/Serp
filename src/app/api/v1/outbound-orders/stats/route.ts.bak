import { NextRequest } from 'next/server';
import { prisma } from '@/lib/prisma';
import {
  successResponse,
  errorResponse,
  validationErrorResponse,
  extractZodErrors,
} from '@/lib/api-response';
import { z } from 'zod';

/**
 * 出库单统计 API
 * 提供出库单的各种统计数据
 */

// 查询参数 Schema
const StatsQuerySchema = z.object({
  startDate: z.string().optional(), // 开始日期 (YYYY-MM-DD)
  endDate: z.string().optional(),   // 结束日期 (YYYY-MM-DD)
  status: z.enum(['DRAFT', 'PENDING', 'SHIPPED', 'CANCELLED']).optional(),
  groupBy: z.enum(['day', 'week', 'month', 'status', 'product']).optional().default('status'),
});

/**
 * GET /api/v1/outbound-orders/stats
 * 获取出库单统计数据
 */
export async function GET(request: NextRequest) {
  try {
    const searchParams = request.nextUrl.searchParams;
    const queryResult = StatsQuerySchema.safeParse(Object.fromEntries(searchParams));

    if (!queryResult.success) {
      return validationErrorResponse(extractZodErrors(queryResult.error));
    }

    const { startDate, endDate, status, groupBy } = queryResult.data;

    // 构建查询条件
    const where: any = {};

    if (status) {
      where.status = status;
    }

    if (startDate || endDate) {
      where.createdAt = {};
      if (startDate) {
        where.createdAt.gte = new Date(startDate);
      }
      if (endDate) {
        where.createdAt.lte = new Date(endDate + 'T23:59:59.999Z');
      }
    }

    // 按状态统计
    if (groupBy === 'status') {
      const statusStats = await prisma.outboundOrder.groupBy({
        by: ['status'],
        where,
        _count: {
          id: true,
        },
        _sum: {
          items: {
            quantity: true,
            amount: true,
          },
        },
      });

      const stats = statusStats.map(item => ({
        status: item.status,
        count: item._count.id,
        totalQuantity: item._sum.items?.quantity || 0,
        totalAmount: item._sum.items?.amount || 0,
      }));

      return successResponse({
        groupBy: 'status',
        data: stats,
      }, 'SUCCESS');
    }

    // 按日期统计（天/周/月）
    if (['day', 'week', 'month'].includes(groupBy)) {
      const orders = await prisma.outboundOrder.findMany({
        where,
        include: {
          items: true,
        },
        orderBy: {
          createdAt: 'asc',
        },
      });

      // 按日期分组
      const groupedData: Record<string, any> = {};

      orders.forEach(order => {
        let dateKey: string;
        const date = new Date(order.createdAt);

        if (groupBy === 'day') {
          dateKey = date.toISOString().split('T')[0];
        } else if (groupBy === 'week') {
          // 获取周数
          const startOfYear = new Date(date.getFullYear(), 0, 1);
          const weekNum = Math.ceil(((date.getTime() - startOfYear.getTime()) / 86400000 + startOfYear.getDay() + 1) / 7);
          dateKey = `${date.getFullYear()}-W${String(weekNum).padStart(2, '0')}`;
        } else {
          // 按月
          dateKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
        }

        if (!groupedData[dateKey]) {
          groupedData[dateKey] = {
            date: dateKey,
            count: 0,
            totalQuantity: 0,
            totalAmount: 0,
          };
        }

        groupedData[dateKey].count++;
        order.items.forEach(item => {
          groupedData[dateKey].totalQuantity += item.quantity;
          groupedData[dateKey].totalAmount += Number(item.amount);
        });
      });

      const stats = Object.values(groupedData).sort((a: any, b: any) => 
        a.date.localeCompare(b.date)
      );

      return successResponse({
        groupBy,
        data: stats,
      }, 'SUCCESS');
    }

    // 按产品统计
    if (groupBy === 'product') {
      const productStats = await prisma.outboundOrderItem.groupBy({
        by: ['productId'],
        where: {
          outboundOrder: where,
        },
        _sum: {
          quantity: true,
          amount: true,
        },
        _count: {
          id: true,
        },
      });

      // 获取产品信息
      const productIds = productStats.map(item => item.productId);
      const products = await prisma.product.findMany({
        where: {
          id: { in: productIds },
        },
        select: {
          id: true,
          name: true,
          sku: true,
        },
      });

      const productMap = new Map(products.map(p => [p.id, p]));

      const stats = productStats.map(item => ({
        productId: item.productId,
        productName: productMap.get(item.productId)?.name || 'Unknown',
        productSku: productMap.get(item.productId)?.sku || 'Unknown',
        orderCount: item._count.id,
        totalQuantity: item._sum.quantity || 0,
        totalAmount: item._sum.amount || 0,
      })).sort((a, b) => b.totalQuantity - a.totalQuantity);

      return successResponse({
        groupBy: 'product',
        data: stats,
      }, 'SUCCESS');
    }

    // 默认返回总体统计
    const total = await prisma.outboundOrder.count({ where });
    const itemsStats = await prisma.outboundOrderItem.aggregate({
      where: {
        outboundOrder: where,
      },
      _sum: {
        quantity: true,
        amount: true,
      },
      _count: {
        id: true,
      },
    });

    return successResponse({
      groupBy: 'total',
      data: {
        totalOrders: total,
        totalItems: itemsStats._count.id,
        totalQuantity: itemsStats._sum.quantity || 0,
        totalAmount: itemsStats._sum.amount || 0,
      },
    }, 'SUCCESS');
  } catch (error) {
    console.error('Error fetching outbound order stats:', error);
    return errorResponse('获取统计数据失败');
  }
}
