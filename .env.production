NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://trade_erp:trade_erp_password@host.docker.internal:5432/trade_erp?schema=public

# JWT 认证配置（生产环境必须修改为随机生成的密钥）
JWT_SECRET=trade-erp-production-jwt-secret-change-this-in-real-deployment
NEXTAUTH_SECRET=trade-erp-nextauth-secret-change-this-in-real-deployment
NEXTAUTH_URL=http://localhost:3000
