// ============================================
// Trade ERP v0.8.0 - Database Schema Changes
// 新增表结构：权限系统 + 多平台 + 海外仓 + 审批 + 财务 + 利润核算 + 绩效提成
// ============================================

// ==================== 1. 权限系统 - RBAC ====================

// 权限表
model Permission {
  id          String    @id @default(cuid())
  name        String    // 权限名称，如: order.create, order.approve
  displayName String    // 显示名称
  module      String    // 所属模块: system/auth/order/product/warehouse/finance/profit/performance
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  roles       RolePermission[]

  @@unique([name])
  @@index([module, isActive])
  @@map("permissions")
}

// 扩展角色表（原 User 有 role 字段，这里支持多角色）
model Role {
  id          String    @id @default(cuid())
  name        String    // 角色名称: super_admin/admin/manager/sales/warehouse/finance/observer
  displayName String    // 显示名称
  description String?
  isSystem    Boolean   @default(false)  // 系统角色不可删除
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       UserRole[]
  permissions RolePermission[]

  @@unique([name])
  @@index([isActive])
  @@map("roles")
}

// 用户-角色关联表
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// 角色-权限关联表
model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime    @default(now())
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// 扩展 User 表关系（需在原 schema 中添加）
// 用户表已存在，这里添加关系声明：
// users       UserRole[]
// 原 User.role 字段保留作为默认角色

// 用户注册审批表（新用户注册需要审批）
model UserRegistration {
  id           String         @id @default(cuid())
  username     String
  email        String         @unique
  passwordHash String
  name         String?
  phone        String?
  department   String?
  position     String?
  status       RegStatus      @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  rejectReason String?
  remarks      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  approvedBy   User?          @relation(fields: [approvedById], references: [id])

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("user_registrations")
}

enum RegStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== 2. 多平台集成 ====================

// 平台类型枚举
enum PlatformType {
  ALIBABA       // 阿里国际站
  ALIBABA_1688  // 1688
  AMAZON        // 亚马逊
  TIKTOK        // TikTok Shop
  SHOPIFY       // Shopify
  WISH          // Wish
  EBAY          // eBay
  OTHER         // 其他
}

// 平台账号表
model PlatformAccount {
  id               String        @id @default(cuid())
  platformType     PlatformType  // 平台类型
  platformName     String        // 平台名称显示
  accountName      String        // 账号名称/店铺名
  accountId        String?       // 平台账号ID
  shopId           String?       // 店铺ID
  clientId         String?       // API Client ID
  clientSecret     String?       // API Client Secret (加密存储)
  accessToken      String?       // Access Token (加密存储)
  refreshToken     String?       // Refresh Token (加密存储)
  tokenExpiresAt   DateTime?     // Token 过期时间
  apiKey           String?       // API Key (部分平台)
  apiSecret        String?       // API Secret (加密存储)
  authCode         String?       // 授权码
  region           String?       // 站点区域: US/EU/SE/...
  currency         String        @default("USD")
  isTest           Boolean       @default(false)  // 是否沙箱测试
  isActive         Boolean       @default(true)
  lastSyncAt       DateTime?     // 最后同步时间
  syncStatus       String?       // last sync status
  errorMessage     String?       // last sync error
  userId           String?       // 负责人ID
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  orders           PlatformOrder[]
  user             User?         @relation(fields: [userId], references: [id])

  @@index([platformType, isActive])
  @@index([userId])
  @@index([accountId])
  @@index([shopId])
  @@map("platform_accounts")
}

// 平台订单表（同步各平台订单）
model PlatformOrder {
  id                String          @id @default(cuid())
  platformOrderId   String          // 平台订单ID
  platformOrderSn   String?         // 平台订单号
  platformAccountId String          // 关联平台账号
  platformType      PlatformType    // 平台类型
  sellerId          String?         // 卖家ID
  buyerId           String?         // 买家ID
  buyerName         String?         // 买家名称
  buyerEmail        String?         // 买家邮箱
  buyerPhone        String?         // 买家电话
  status            String          // 平台订单状态
  paymentStatus     String?         // 支付状态
  fulfillmentStatus String?         // 发货状态
  orderDate         DateTime?       // 订单创建时间
  paymentDate       DateTime?       // 支付时间
  shipmentDate      DateTime?       // 发货时间
  deliveryDate      DateTime?       // 送达时间
  currency          String          @default("USD")
  totalAmount       Decimal         @db.Decimal(12, 2)  // 订单总额
  subtotal          Decimal?        @db.Decimal(12, 2)  // 商品小计
  shippingFee       Decimal?        @db.Decimal(10, 2)  // 运费
  platformFee       Decimal?        @db.Decimal(10, 2)  // 平台佣金
  commissionFee     Decimal?        @db.Decimal(10, 2)  // 佣金
  tax               Decimal?        @db.Decimal(10, 2)  // 税费
  discount          Decimal?        @db.Decimal(10, 2)  // 折扣
  coupon            Decimal?        @db.Decimal(10, 2)  // 优惠券
  shippingAddress   Json?           // 收货地址JSON
  billingAddress    Json?           // 账单地址JSON
  buyerMessage      String?         // 买家留言
  notes             String?         // 内部备注
  internalOrderId   String?         // 关联内部ERP订单ID
  items             Json            @default("[]")      // 订单商品明细JSON
  tags              String[]        // 标签
  syncVersion       Int             @default(1)        // 同步版本号
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  profitDetails     ProfitDetail[]

  @@unique([platformOrderId, platformAccountId])  // 同一账号下平台订单ID唯一
  @@index([platformAccountId, orderDate])
  @@index([platformType, status])
  @@index([internalOrderId])
  @@index([orderDate])
  @@map("platform_orders")
}

// ==================== 3. 海外仓管理 ====================

// 海外仓类型枚举
enum OverseasWarehouseType {
  FBA          // 亚马逊FBA仓
  FBN          //  TikTok FBN
  SELF_OWNED   // 自营海外仓
  THIRD_PARTY  // 第三方海外仓
}

// 海外仓表
model OverseasWarehouse {
  id            String                 @id @default(cuid())
  name          String                 // 仓库名称
  code          String                 @unique  // 仓库编码
  type          OverseasWarehouseType  // 仓库类型
  country       String                 // 国家
  province      String?                // 省/州
  city          String?                // 城市
  address       String                 // 地址
  postcode      String?                // 邮编
  contactName   String?                // 联系人
  contactPhone  String?                // 联系电话
  email         String?                // 邮箱
  warehouseId   String?                // 平台仓库ID (如FBA仓库ID)
  region        String?                // 区域代码
  timezone      String                 @default("UTC") // 时区
  isActive      Boolean                @default(true)
  apiEnabled    Boolean                @default(false) // 是否启用API同步
  apiKey        String?                // API密钥 (加密)
  apiUrl        String?                // API地址
  fbaSyncEnabled Boolean               @default(false) // FBA库存同步
  lastSyncAt    DateTime?              // 最后同步时间
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  inventory     OverseasInventory[]

  @@index([type, country, isActive])
  @@index([code])
  @@map("overseas_warehouses")
}

// 海外仓库存
model OverseasInventory {
  id                String              @id @default(cuid())
  warehouseId       String
  productId         String
  sku               String
  fnsku             String?             // FBA FNSKU
  asin              String?             // ASIN
  availableQty      Int                 @default(0)  // 可售数量
  inboundQty        Int                 @default(0)  // 在途数量
  reservedQty       Int                 @default(0)  // 预留数量
  totalQty          Int                 @default(0)  // 总数量
  lastFulfillableQty Int?              // 最后同步可售数量
  costPerUnit       Decimal?            @db.Decimal(10, 2) // 单位成本
  location          String?             // 库位
  lastSyncAt        DateTime?           // 最后同步时间
  updatedAtSource   DateTime?           // 来源更新时间
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  warehouse         OverseasWarehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product           Product             @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([sku])
  @@index([fnsku])
  @@index([asin])
  @@map("overseas_inventory")
}

