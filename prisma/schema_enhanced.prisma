// Prisma Schema for Foreign Trade ERP - Enhanced Version
// 外贸 ERP 数据库模型 - 增强版
// 日期：2026-03-06
// 说明：此文件包含订单管理和采购管理的增强模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户与权限
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(USER)
  avatar        String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 销售订单
  salesOrders   Order[]   @relation("SalesRep")
  // 负责的客户
  customers     Customer[] @relation("Owner")
  // 采购订单
  purchaseOrders PurchaseOrder[] @relation("Purchaser")
  // 供应商
  suppliers     Supplier[] @relation("Owner")
  
  @@index([email])
  @@index([role, isActive])
  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  USER
  VIEWER
}

// ============================================
// 客户管理
// ============================================

model Customer {
  id              String    @id @default(cuid())
  companyName     String
  companyEn       String?   // 英文名称
  contactName     String?
  email           String?
  phone           String?
  country         String?
  address         String?   @db.Text
  website         String?
  source          String?   // 客户来源：展会/网站/推荐等
  status          CustomerStatus @default(ACTIVE)
  creditLevel     String?   // 信用评级
  taxId           String?   // 税号
  currency        String    @default("USD")  // 结算币种
  notes           String?   @db.Text
  ownerId         String?
  owner           User?     @relation("Owner", fields: [ownerId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  inquiries       Inquiry[]
  orders          Order[]
  contacts        CustomerContact[]
  quotations      Quotation[]
  
  @@index([email])
  @@index([status, createdAt])
  @@index([ownerId])
  @@index([companyName])
  @@map("customers")
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model CustomerContact {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  position    String?
  email       String?
  phone       String?
  mobile      String?
  wechat      String?
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([customerId])
  @@map("customer_contacts")
}

// ============================================
// 产品管理
// ============================================

model Product {
  id              String    @id @default(cuid())
  sku             String    @unique
  name            String
  nameEn          String?   // 英文名称
  category        String?
  specification   String?   @db.Text
  unit            String    @default("PCS")
  costPrice       Decimal   @db.Decimal(10, 2)
  salePrice       Decimal   @db.Decimal(10, 2)
  currency        String    @default("USD")
  images          String[]
  description     String?   @db.Text
  descriptionEn   String?   @db.Text
  weight          Decimal?  @db.Decimal(10, 2)
  volume          Decimal?  @db.Decimal(10, 2)
  moq             Int?
  leadTime        Int?
  hsCode          String?   // HS 编码
  originCountry   String?   @default("CN")
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  orderItems      OrderItem[]
  quotationItems  QuotationItem[]
  inventoryItems  InventoryItem[]
  purchaseOrderItems PurchaseOrderItem[]
  
  @@index([sku])
  @@index([category, status])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
  DEVELOPING
}

// ============================================
// 询盘管理
// ============================================

model Inquiry {
  id              String    @id @default(cuid())
  inquiryNo       String    @unique
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  source          String?
  status          InquiryStatus @default(NEW)
  priority        Priority  @default(MEDIUM)
  products        String?   @db.Text
  quantity        Int?
  targetPrice     Decimal?  @db.Decimal(10, 2)
  currency        String    @default("USD")
  requirements    String?   @db.Text
  deadline        DateTime?
  assignedTo      String?
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  followUps       FollowUp[]
  
  @@index([customerId, status])
  @@index([status, createdAt])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  NEGOTIATING
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model FollowUp {
  id          String   @id @default(cuid())
  inquiryId   String
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  type        FollowUpType @default(CALL)
  content     String   @db.Text
  nextFollowUp DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([inquiryId])
  @@map("follow_ups")
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  MESSAGE
  OTHER
}

// ============================================
// 报价管理
// ============================================

model Quotation {
  id              String    @id @default(cuid())
  quotationNo     String    @unique
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  inquiryId       String?
  status          QuotationStatus @default(DRAFT)
  currency        String    @default("USD")
  paymentTerms    String?
  deliveryTerms   String?
  validityDays    Int?
  notes           String?   @db.Text
  totalAmount     Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  items           QuotationItem[]
  
  @@index([customerId, status])
  @@index([status, createdAt])
  @@map("quotations")
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuotationItem {
  id              String    @id @default(cuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  productName     String
  specification   String?   @db.Text
  quantity        Int
  unitPrice       Decimal   @db.Decimal(10, 2)
  amount          Decimal   @db.Decimal(12, 2)
  notes           String?
  
  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

// ============================================
// 订单管理 (增强版)
// ============================================

model Order {
  id                  String    @id @default(cuid())
  orderNo             String    @unique
  customerId          String
  customer            Customer  @relation(fields: [customerId], references: [id])
  
  // 溯源
  sourceInquiryId     String?
  sourceQuotationId   String?
  
  // 基本信息
  status              OrderStatus @default(PENDING)
  currency            String    @default("USD")
  exchangeRate        Decimal   @default(1) @db.Decimal(10, 6)
  totalAmount         Decimal   @db.Decimal(12, 2)
  paidAmount          Decimal   @db.Decimal(12, 2) @default(0)
  balanceAmount       Decimal   @db.Decimal(12, 2) @default(0)
  
  // 交易条款
  paymentTerms        String?   @db.Text
  paymentDeadline     DateTime?
  deliveryTerms       String?
  deliveryDate        DateTime?
  deliveryDeadline    DateTime?
  
  // 收货地址
  shippingAddress     String?   @db.Text
  shippingContact     String?
  shippingPhone       String?
  
  // 业务员
  salesRepId          String?
  salesRep            User?     @relation("SalesRep", fields: [salesRepId], references: [id])
  
  // 审批
  approvalStatus      ApprovalStatus @default(NOT_REQUIRED)
  approvedBy          String?
  approvedAt          DateTime?
  
  // 备注
  notes               String?   @db.Text
  internalNotes       String?   @db.Text
  attachments         String[]
  
  // 时间戳
  confirmedAt         DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancelReason        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // 关联
  items               OrderItem[]
  payments            Payment[]
  shipments           Shipment[]
  productionRecords   ProductionRecord[]
  qualityChecks       QualityCheck[]
  
  @@index([customerId, status])
  @@index([salesRepId, createdAt])
  @@index([status, deliveryDate])
  @@index([createdAt])
  @@index([orderNo])
  @@index([sourceInquiryId])
  @@index([sourceQuotationId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  productName     String
  productSku      String?
  specification   String?   @db.Text
  
  quantity        Int       @default(1)
  unit            String    @default("PCS")
  unitPrice       Decimal   @db.Decimal(10, 2)
  discountRate    Decimal   @default(0) @db.Decimal(5, 2)
  amount          Decimal   @db.Decimal(12, 2)
  
  // 生产
  productionStatus ProductionStatus @default(NOT_STARTED)
  productionNote  String?   @db.Text
  estimatedProductionDate DateTime?
  actualProductionDate    DateTime?
  
  // 发货
  shippedQty      Int       @default(0)
  deliveredQty    Int       @default(0)
  
  // 产品信息快照
  productImage    String?
  productWeight   Decimal?  @db.Decimal(10, 2)
  productVolume   Decimal?  @db.Decimal(10, 2)
  hsCode          String?
  originCountry   String?   @default("CN")
  
  notes           String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([orderId])
  @@index([productId])
  @@index([productionStatus])
  @@map("order_items")
}

enum ProductionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
}

// ============================================
// 生产记录 (新增)
// ============================================

model ProductionRecord {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  
  productionNo    String    @unique
  productId       String?
  quantity        Int
  plannedStartDate DateTime
  plannedEndDate  DateTime
  actualStartDate DateTime?
  actualEndDate   DateTime?
  
  status          ProductionRecordStatus @default(PLANNED)
  progress        Int       @default(0)
  
  department      String?
  factory         String?
  supervisor      String?
  
  notes           String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([orderId])
  @@index([status])
  @@map("production_records")
}

enum ProductionRecordStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

// ============================================
// 质检记录 (新增)
// ============================================

model QualityCheck {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  
  qcNo            String    @unique
  type            QualityCheckType @default(FINAL)
  inspector       String?
  inspectionDate  DateTime  @default(now())
  
  status          QualityCheckStatus @default(PENDING)
  passRate        Decimal?  @db.Decimal(5, 2)
  defectCount     Int       @default(0)
  defectReasons   String[]
  
  items           QualityCheckItem[]
  
  photos          String[]
  report          String?
  
  notes           String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([orderId])
  @@index([status])
  @@map("quality_checks")
}

enum QualityCheckType {
  RAW_MATERIAL
  IN_PROCESS
  FINAL
  PRE_SHIPMENT
}

enum QualityCheckStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  CONDITIONAL
}

model QualityCheckItem {
  id              String    @id @default(cuid())
  qualityCheckId  String
  qualityCheck    QualityCheck @relation(fields: [qualityCheckId], references: [id], onDelete: Cascade)
  
  itemName        String
  standard        String?
  result          String?
  passed          Boolean
  
  @@map("quality_check_items")
}

// ============================================
// 收款管理
// ============================================

model Payment {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  paymentNo       String    @unique
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("USD")
  paymentMethod   String?
  paymentDate     DateTime?
  bankReference   String?
  notes           String?   @db.Text
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([orderId])
  @@index([paymentDate])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// 发货管理
// ============================================

model Shipment {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  shipmentNo      String    @unique
  carrier         String?
  trackingNo      String?
  etd             DateTime?
  eta             DateTime?
  portOfLoading   String?
  portOfDischarge String?
  containerNo     String?
  sealNo          String?
  packages        Int?
  grossWeight     Decimal?  @db.Decimal(10, 2)
  volume          Decimal?  @db.Decimal(10, 2)
  status          ShipmentStatus @default(PENDING)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([orderId])
  @@index([status])
  @@map("shipments")
}

enum ShipmentStatus {
  PENDING
  BOOKED
  IN_TRANSIT
  SHIPPED
  DELIVERED
}

// ============================================
// 采购管理 (增强版)
// ============================================

model Supplier {
  id              String    @id @default(cuid())
  supplierNo      String    @unique
  companyName     String
  companyEn       String?
  contactName     String?
  contactTitle    String?
  email           String?
  phone           String?
  mobile          String?
  fax             String?
  
  address         String?   @db.Text
  city            String?
  province        String?
  country         String?   @default("CN")
  postalCode      String?
  
  website         String?
  taxId           String?
  businessLicense String?
  bankName        String?
  bankAccount     String?
  bankCode        String?
  
  products        String?   @db.Text
  categories      String[]
  
  status          SupplierStatus @default(ACTIVE)
  type            SupplierType @default(DOMESTIC)
  level           SupplierLevel @default(NORMAL)
  score           Decimal?  @db.Decimal(3, 2)
  
  creditTerms     String?
  paymentMethods  String[]
  currency        String    @default("CNY")
  minOrderAmount  Decimal?  @db.Decimal(12, 2)
  
  totalOrders     Int       @default(0)
  totalAmount     Decimal   @default(0) @db.Decimal(14, 2)
  lastOrderDate   DateTime?
  
  ownerId         String?
  owner           User?     @relation("Purchaser", fields: [ownerId], references: [id])
  
  notes           String?   @db.Text
  attachments     String[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  purchaseOrders  PurchaseOrder[]
  contacts        SupplierContact[]
  evaluations     SupplierEvaluation[]
  
  @@index([status])
  @@index([companyName])
  @@index([ownerId])
  @@index([type, level])
  @@map("suppliers")
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  PENDING
}

enum SupplierType {
  DOMESTIC
  OVERSEAS
}

enum SupplierLevel {
  STRATEGIC
  PREFERRED
  NORMAL
  RESTRICTED
}

model SupplierContact {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  name        String
  title       String?
  department  String?
  email       String?
  phone       String?
  mobile      String?
  wechat      String?
  qq          String?
  isPrimary   Boolean  @default(false)
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([supplierId])
  @@map("supplier_contacts")
}

model PurchaseOrder {
  id              String    @id @default(cuid())
  poNo            String    @unique
  
  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  
  salesOrderId    String?
  salesOrder      Order?    @relation(fields: [salesOrderId], references: [id])
  
  status          PurchaseOrderStatus @default(PENDING)
  approvalStatus  ApprovalStatus @default(NOT_REQUIRED)
  
  currency        String    @default("CNY")
  exchangeRate    Decimal   @default(1) @db.Decimal(10, 6)
  totalAmount     Decimal   @db.Decimal(12, 2)
  paidAmount      Decimal   @db.Decimal(12, 2) @default(0)
  balanceAmount   Decimal   @db.Decimal(12, 2) @default(0)
  
  deliveryDate    DateTime?
  deliveryDeadline DateTime?
  deliveryAddress String?   @db.Text
  shippingMethod  String?
  
  paymentTerms    String?
  paymentDeadline DateTime?
  
  purchaserId     String?
  purchaser       User?     @relation("Purchaser", fields: [purchaserId], references: [id])
  
  notes           String?   @db.Text
  internalNotes   String?   @db.Text
  attachments     String[]
  
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  items           PurchaseOrderItem[]
  receipts        PurchaseReceipt[]
  payments        SupplierPayment[]
  
  @@index([supplierId, status])
  @@index([salesOrderId])
  @@index([status, deliveryDate])
  @@index([createdAt])
  @@index([poNo])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  RECEIVED
  COMPLETED
  CANCELLED
}

model PurchaseOrderItem {
  id              String    @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  productName     String
  productSku      String?
  specification   String?   @db.Text
  unit            String    @default("PCS")
  
  quantity        Int       @default(1)
  unitPrice       Decimal   @db.Decimal(10, 2)
  discountRate    Decimal   @default(0) @db.Decimal(5, 2)
  amount          Decimal   @db.Decimal(12, 2)
  taxRate         Decimal   @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal   @db.Decimal(12, 2) @default(0)
  
  receivedQty     Int       @default(0)
  rejectedQty     Int       @default(0)
  
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  
  notes           String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ============================================
// 采购入库 (新增)
// ============================================

model PurchaseReceipt {
  id              String    @id @default(cuid())
  receiptNo       String    @unique
  
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  
  warehouse       String    @default("MAIN")
  receiptDate     DateTime  @default(now())
  receiptBy       String?
  
  status          ReceiptStatus @default(PENDING)
  
  qualityCheckId  String?
  qualityStatus   QualityCheckStatus @default(PENDING)
  
  notes           String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  items           PurchaseReceiptItem[]
  
  @@index([purchaseOrderId])
  @@index([warehouse])
  @@index([receiptDate])
  @@map("purchase_receipts")
}

enum ReceiptStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

model PurchaseReceiptItem {
  id              String    @id @default(cuid())
  receiptId       String
  receipt         PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  
  purchaseOrderItemId String
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  
  quantity        Int       @default(1)
  acceptedQty     Int       @default(0)
  rejectedQty     Int       @default(0)
  
  warehouse       String    @default("MAIN")
  location        String?
  
  notes           String?
  
  createdAt       DateTime  @default(now())
  
  @@index([receiptId])
  @@map("purchase_receipt_items")
}

// ============================================
// 供应商付款 (新增)
// ============================================

model SupplierPayment {
  id              String    @id @default(cuid())
  paymentNo       String    @unique
  
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("CNY")
  paymentMethod   String?
  paymentDate     DateTime?
  
  bankName        String?
  bankAccount     String?
  bankReference   String?
  
  status          PaymentStatus @default(PENDING)
  
  notes           String?   @db.Text
  attachments     String[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([purchaseOrderId])
  @@index([paymentDate])
  @@map("supplier_payments")
}

// ============================================
// 供应商评估 (新增)
// ============================================

model SupplierEvaluation {
  id              String    @id @default(cuid())
  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  
  evaluationDate  DateTime  @default(now())
  evaluatorId     String?
  period          String
  
  qualityScore    Decimal   @db.Decimal(2, 1)
  deliveryScore   Decimal   @db.Decimal(2, 1)
  priceScore      Decimal   @db.Decimal(2, 1)
  serviceScore    Decimal   @db.Decimal(2, 1)
  
  totalScore      Decimal   @db.Decimal(3, 2)
  level           SupplierLevel
  
  comments        String?   @db.Text
  improvementPlan String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([supplierId, period])
  @@map("supplier_evaluations")
}

// ============================================
// 库存管理
// ============================================

model InventoryItem {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  warehouse       String    @default("MAIN")
  quantity        Int       @default(0)
  reservedQty     Int       @default(0)
  availableQty    Int       @default(0)
  location        String?
  lastCountedAt   DateTime?
  version         Int       @default(0)  // 乐观锁
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([productId, warehouse])
  @@index([productId])
  @@index([warehouse])
  @@map("inventory_items")
}

model StockMovement {
  id              String    @id @default(cuid())
  productId       String
  warehouse       String    @default("MAIN")
  type            MovementType
  quantity        Int
  referenceType   String?
  referenceId     String?
  notes           String?
  createdAt       DateTime  @default(now())
  
  @@index([productId])
  @@index([warehouse])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RETURN
}

// ============================================
// 审计日志 (新增)
// ============================================

model AuditLog {
  id              String    @id @default(cuid())
  action          String
  entityType      String
  entityId        String
  userId          String?
  details         Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
