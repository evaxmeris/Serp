generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String?
  role           Role            @default(USER)
  avatar         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  customers      Customer[]      @relation("Owner")
  orders         Order[]         @relation("SalesRep")
  purchaseOrders PurchaseOrder[] @relation("Purchaser")
  suppliers      Supplier[]      @relation("Owner")

  @@map("users")
}

model Customer {
  id          String            @id @default(cuid())
  companyName String
  contactName String?
  email       String?
  phone       String?
  country     String?
  address     String?
  website     String?
  source      String?
  status      CustomerStatus    @default(ACTIVE)
  creditLevel String?
  notes       String?
  ownerId     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  contacts    CustomerContact[]
  owner       User?             @relation("Owner", fields: [ownerId], references: [id])
  inquiries   Inquiry[]
  orders      Order[]
  quotations  Quotation[]

  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  position   String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_contacts")
}

model Product {
  id                 String              @id @default(cuid())
  sku                String              @unique
  name               String
  nameEn             String?
  category           String?
  specification      String?
  unit               String              @default("PCS")
  costPrice          Decimal             @db.Decimal(10, 2)
  salePrice          Decimal             @db.Decimal(10, 2)
  currency           String              @default("USD")
  images             String[]
  description        String?
  descriptionEn      String?
  weight             Decimal?            @db.Decimal(10, 2)
  volume             Decimal?            @db.Decimal(10, 2)
  moq                Int?
  leadTime           Int?
  status             ProductStatus       @default(ACTIVE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryItems     InventoryItem[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  quotationItems     QuotationItem[]

  @@map("products")
}

model Inquiry {
  id           String        @id @default(cuid())
  inquiryNo    String        @unique
  customerId   String
  source       String?
  status       InquiryStatus @default(NEW)
  priority     Priority      @default(MEDIUM)
  products     String?
  quantity     Int?
  targetPrice  Decimal?      @db.Decimal(10, 2)
  currency     String        @default("USD")
  requirements String?
  deadline     DateTime?
  assignedTo   String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  followUps    FollowUp[]
  customer     Customer      @relation(fields: [customerId], references: [id])

  @@map("inquiries")
}

model FollowUp {
  id           String       @id @default(cuid())
  inquiryId    String
  type         FollowUpType @default(CALL)
  content      String
  nextFollowUp DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  inquiry      Inquiry      @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@map("follow_ups")
}

model Quotation {
  id            String          @id @default(cuid())
  quotationNo   String          @unique
  customerId    String
  inquiryId     String?
  status        QuotationStatus @default(DRAFT)
  currency      String          @default("USD")
  paymentTerms  String?
  deliveryTerms String?
  validityDays  Int?
  notes         String?
  totalAmount   Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         QuotationItem[]
  customer      Customer        @relation(fields: [customerId], references: [id])

  @@map("quotations")
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  productId     String?
  productName   String
  specification String?
  quantity      Int
  unitPrice     Decimal   @db.Decimal(10, 2)
  amount        Decimal   @db.Decimal(12, 2)
  notes         String?
  product       Product?  @relation(fields: [productId], references: [id])
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model Order {
  id                String             @id @default(cuid())
  orderNo           String             @unique
  customerId        String
  sourceInquiryId   String?
  sourceQuotationId String?
  status            OrderStatus        @default(PENDING)
  currency          String             @default("USD")
  exchangeRate      Decimal            @default(1) @db.Decimal(10, 6)
  totalAmount       Decimal            @db.Decimal(12, 2)
  paidAmount        Decimal            @default(0) @db.Decimal(12, 2)
  balanceAmount     Decimal            @default(0) @db.Decimal(12, 2)
  paymentTerms      String?
  paymentDeadline   DateTime?
  deliveryTerms     String?
  deliveryDate      DateTime?
  deliveryDeadline  DateTime?
  shippingAddress   String?
  shippingContact   String?
  shippingPhone     String?
  salesRepId        String?
  approvalStatus    ApprovalStatus     @default(NOT_REQUIRED)
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  internalNotes     String?
  attachments       String[]
  confirmedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  items             OrderItem[]
  customer          Customer           @relation(fields: [customerId], references: [id])
  salesRep          User?              @relation("SalesRep", fields: [salesRepId], references: [id])
  payments          Payment[]
  productionRecords ProductionRecord[]
  purchaseOrders    PurchaseOrder[]    @relation("SalesOrder")
  qualityChecks     QualityCheck[]
  shipments         Shipment[]

  @@index([customerId, status])
  @@index([salesRepId, createdAt])
  @@index([status, deliveryDate])
  @@index([createdAt])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id                      String           @id @default(cuid())
  orderId                 String
  productId               String?
  productName             String
  productSku              String?
  specification           String?
  quantity                Int              @default(1)
  unit                    String           @default("PCS")
  unitPrice               Decimal          @db.Decimal(10, 2)
  discountRate            Decimal          @default(0) @db.Decimal(5, 2)
  amount                  Decimal          @db.Decimal(12, 2)
  productionStatus        ProductionStatus @default(NOT_STARTED)
  productionNote          String?
  estimatedProductionDate DateTime?
  actualProductionDate    DateTime?
  shippedQty              Int              @default(0)
  deliveredQty            Int              @default(0)
  productImage            String?
  productWeight           Decimal?         @db.Decimal(10, 2)
  productVolume           Decimal?         @db.Decimal(10, 2)
  hsCode                  String?
  originCountry           String?          @default("CN")
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  order                   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                 Product?         @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model ProductionRecord {
  id               String                 @id @default(cuid())
  orderId          String
  productionNo     String                 @unique
  productId        String?
  quantity         Int
  plannedStartDate DateTime
  plannedEndDate   DateTime
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  status           ProductionRecordStatus @default(PLANNED)
  progress         Int                    @default(0)
  department       String?
  factory          String?
  supervisor       String?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  order            Order                  @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("production_records")
}

model QualityCheck {
  id             String             @id @default(cuid())
  orderId        String
  qcNo           String             @unique
  type           QualityCheckType   @default(FINAL)
  inspector      String?
  inspectionDate DateTime           @default(now())
  status         QualityCheckStatus @default(PENDING)
  passRate       Decimal?           @db.Decimal(5, 2)
  defectCount    Int?               @default(0)
  defectReasons  String[]
  photos         String[]
  report         String?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  items          QualityCheckItem[]
  order          Order              @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("quality_checks")
}

model QualityCheckItem {
  id             String       @id @default(cuid())
  qualityCheckId String
  itemName       String
  standard       String?
  result         String?
  passed         Boolean
  qualityCheck   QualityCheck @relation(fields: [qualityCheckId], references: [id], onDelete: Cascade)

  @@map("quality_check_items")
}

model Payment {
  id            String    @id @default(cuid())
  orderId       String
  paymentNo     String    @unique
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  paymentMethod String?
  paymentDate   DateTime?
  bankReference String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  order         Order     @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Shipment {
  id              String         @id @default(cuid())
  orderId         String
  shipmentNo      String         @unique
  carrier         String?
  trackingNo      String?
  etd             DateTime?
  eta             DateTime?
  portOfLoading   String?
  portOfDischarge String?
  containerNo     String?
  sealNo          String?
  packages        Int?
  grossWeight     Decimal?       @db.Decimal(10, 2)
  volume          Decimal?       @db.Decimal(10, 2)
  status          ShipmentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  order           Order          @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

model Supplier {
  id              String               @id @default(cuid())
  supplierNo      String               @unique
  companyName     String
  companyEn       String?
  contactName     String?
  contactTitle    String?
  email           String?
  phone           String?
  mobile          String?
  fax             String?
  address         String?
  city            String?
  province        String?
  country         String?              @default("CN")
  postalCode      String?
  website         String?
  taxId           String?
  businessLicense String?
  bankName        String?
  bankAccount     String?
  bankCode        String?
  products        String?
  categories      String[]
  status          SupplierStatus       @default(ACTIVE)
  type            SupplierType         @default(DOMESTIC)
  level           SupplierLevel        @default(NORMAL)
  score           Decimal?             @db.Decimal(3, 2)
  creditTerms     String?
  paymentMethods  String[]
  currency        String               @default("CNY")
  minOrderAmount  Decimal?             @db.Decimal(12, 2)
  totalOrders     Int                  @default(0)
  totalAmount     Decimal              @default(0) @db.Decimal(14, 2)
  lastOrderDate   DateTime?
  ownerId         String?
  notes           String?
  attachments     String[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  purchaseOrders  PurchaseOrder[]
  contacts        SupplierContact[]
  evaluations     SupplierEvaluation[]
  owner           User?                @relation("Owner", fields: [ownerId], references: [id])

  @@index([status])
  @@index([companyName])
  @@index([ownerId])
  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  title      String?
  department String?
  email      String?
  phone      String?
  mobile     String?
  wechat     String?
  qq         String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_contacts")
}

model SupplierEvaluation {
  id              String        @id @default(cuid())
  supplierId      String
  evaluationDate  DateTime      @default(now())
  evaluatorId     String?
  period          String
  qualityScore    Decimal       @db.Decimal(2, 1)
  deliveryScore   Decimal       @db.Decimal(2, 1)
  priceScore      Decimal       @db.Decimal(2, 1)
  serviceScore    Decimal       @db.Decimal(2, 1)
  totalScore      Decimal       @db.Decimal(3, 2)
  level           SupplierLevel
  comments        String?
  improvementPlan String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  supplier        Supplier      @relation(fields: [supplierId], references: [id])

  @@index([supplierId, period])
  @@map("supplier_evaluations")
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  poNo             String              @unique
  supplierId       String
  salesOrderId     String?
  status           PurchaseOrderStatus @default(PENDING)
  approvalStatus   ApprovalStatus      @default(NOT_REQUIRED)
  currency         String              @default("CNY")
  exchangeRate     Decimal             @default(1) @db.Decimal(10, 6)
  totalAmount      Decimal             @db.Decimal(12, 2)
  paidAmount       Decimal             @default(0) @db.Decimal(12, 2)
  balanceAmount    Decimal             @default(0) @db.Decimal(12, 2)
  deliveryDate     DateTime?
  deliveryDeadline DateTime?
  deliveryAddress  String?
  shippingMethod   String?
  paymentTerms     String?
  paymentDeadline  DateTime?
  purchaserId      String?
  notes            String?
  internalNotes    String?
  attachments      String[]
  confirmedAt      DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  items            PurchaseOrderItem[]
  purchaser        User?               @relation("Purchaser", fields: [purchaserId], references: [id])
  salesOrder       Order?              @relation("SalesOrder", fields: [salesOrderId], references: [id])
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  receipts         PurchaseReceipt[]
  payments         SupplierPayment[]

  @@index([supplierId, status])
  @@index([salesOrderId])
  @@index([status, deliveryDate])
  @@index([createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                   String                @id @default(cuid())
  purchaseOrderId      String
  productId            String?
  productName          String
  productSku           String?
  specification        String?
  unit                 String                @default("PCS")
  quantity             Int                   @default(1)
  unitPrice            Decimal               @db.Decimal(10, 2)
  discountRate         Decimal               @default(0) @db.Decimal(5, 2)
  amount               Decimal               @db.Decimal(12, 2)
  taxRate              Decimal               @default(0) @db.Decimal(5, 2)
  taxAmount            Decimal               @default(0) @db.Decimal(12, 2)
  receivedQty          Int                   @default(0)
  rejectedQty          Int                   @default(0)
  pendingQty           Int                   @default(0)
  expectedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  product              Product?              @relation(fields: [productId], references: [id])
  purchaseOrder        PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receiptItems         PurchaseReceiptItem[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id              String                @id @default(cuid())
  receiptNo       String                @unique
  purchaseOrderId String
  warehouse       String                @default("MAIN")
  receiptDate     DateTime              @default(now())
  receiptBy       String?
  status          ReceiptStatus         @default(PENDING)
  qualityCheckId  String?
  qualityStatus   QualityCheckStatus    @default(PENDING)
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  items           PurchaseReceiptItem[]
  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([warehouse])
  @@index([receiptDate])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                  String            @id @default(cuid())
  receiptId           String
  purchaseOrderItemId String
  quantity            Int               @default(1)
  acceptedQty         Int               @default(0)
  rejectedQty         Int               @default(0)
  warehouse           String            @default("MAIN")
  location            String?
  notes               String?
  createdAt           DateTime          @default(now())
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  receipt             PurchaseReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@map("purchase_receipt_items")
}

model SupplierPayment {
  id              String        @id @default(cuid())
  paymentNo       String        @unique
  purchaseOrderId String
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("CNY")
  paymentMethod   String?
  paymentDate     DateTime?
  bankName        String?
  bankAccount     String?
  bankReference   String?
  status          PaymentStatus @default(PENDING)
  notes           String?
  attachments     String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([paymentDate])
  @@map("supplier_payments")
}

model InventoryItem {
  id            String    @id @default(cuid())
  productId     String
  warehouse     String    @default("MAIN")
  quantity      Int       @default(0)
  reservedQty   Int       @default(0)
  availableQty  Int       @default(0)
  location      String?
  lastCountedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  product       Product   @relation(fields: [productId], references: [id])

  @@unique([productId, warehouse])
  @@map("inventory_items")
}

model StockMovement {
  id            String       @id @default(cuid())
  productId     String
  warehouse     String       @default("MAIN")
  type          MovementType
  quantity      Int
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime     @default(now())

  @@map("stock_movements")
}

enum Role {
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
  DEVELOPING
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  NEGOTIATING
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  MESSAGE
  OTHER
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum ProductionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum ProductionRecordStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum QualityCheckType {
  RAW_MATERIAL
  IN_PROCESS
  FINAL
  PRE_SHIPMENT
}

enum QualityCheckStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  CONDITIONAL
}

enum ShipmentStatus {
  PENDING
  BOOKED
  IN_TRANSIT
  SHIPPED
  DELIVERED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  PENDING
}

enum SupplierType {
  DOMESTIC
  OVERSEAS
}

enum SupplierLevel {
  STRATEGIC
  PREFERRED
  NORMAL
  RESTRICTED
}

enum PurchaseOrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  RECEIVED
  COMPLETED
  CANCELLED
}

enum ReceiptStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RETURN
}
