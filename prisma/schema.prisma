// ==================== Sprint 5: 出库订单模型 ====================

model OutboundOrder {
  id            String              @id @default(cuid())
  outboundNo    String              @unique @default(cuid())
  orderId       String // 关联销售订单
  warehouseId   String // 关联仓库
  status        String // draft/pending/confirmed/cancelled
  totalAmount   Decimal?
  items         OutboundOrderItem[]
  shipment      Shipment?           @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  inventoryLogs InventoryLog[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade, name: "OrderOutboundOrders")
  shipmentId    String?

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("outbound_orders")
}

model OutboundOrderItem {
  id              String        @id @default(cuid())
  outboundOrderId String
  productId       String
  quantity        Int
  shippedQuantity Int           @default(0)
  unitPrice       Decimal?
  outboundOrder   OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([outboundOrderId])
  @@index([productId])
  @@map("outbound_order_items")
}

// ==================== Sprint 6: 财务报表模块 ====================

// 报表定义表 - 存储报表的元数据和配置
model ReportDefinition {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String // PROFIT/SALES/INVENTORY/PURCHASE/CASHFLOW/CUSTOM
  description String?
  config      Json     @default("{}")
  columns     Json     @default("[]")
  filters     Json     @default("[]")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联关系
  data          ReportData[]
  subscriptions ReportSubscription[]
  exportLogs    ReportExportLog[]
  schedules     ReportSchedule[]

  @@index([type])
  @@index([isActive])
  @@map("report_definitions")
}

// 报表数据表 - 存储生成的报表数据
model ReportData {
  id          String   @id @default(cuid())
  reportId    String
  period      String // 2026-03 / 2026-Q1 / 2026
  periodStart DateTime
  periodEnd   DateTime
  data        Json     @default("{}")
  metrics     Json     @default("{}")
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  // 关联关系
  report ReportDefinition @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([period])
  @@index([periodStart, periodEnd])
  @@map("report_data")
}

// 订阅配置表 - 用户订阅报表推送
model ReportSubscription {
  id         String    @id @default(cuid())
  reportId   String
  userId     String
  frequency  String // DAILY/WEEKLY/MONTHLY
  format     String    @default("pdf") // pdf/excel/csv
  email      String?
  isActive   Boolean   @default(true)
  lastSentAt DateTime?
  nextSendAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // 关联关系
  report ReportDefinition @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([userId])
  @@index([isActive])
  @@map("report_subscriptions")
}

// 导出日志表 - 记录报表导出历史
model ReportExportLog {
  id           String    @id @default(cuid())
  reportId     String
  userId       String
  exportType   String // IMMEDIATE/SCHEDULED
  format       String // pdf/excel/csv
  fileUrl      String?
  fileSize     Int?
  status       String    @default("pending") // pending/completed/failed
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  // 关联关系
  report ReportDefinition @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([userId])
  @@index([status])
  @@map("report_export_logs")
}

// 定时任务表 - 报表自动生成调度
model ReportSchedule {
  id             String    @id @default(cuid())
  reportId       String
  name           String
  cronExpression String
  timezone       String    @default("Asia/Shanghai")
  config         Json      @default("{}")
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 关联关系
  report ReportDefinition @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([isActive])
  @@map("report_schedules")
}
