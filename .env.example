# Database
DATABASE_URL="postgresql://trade_erp:***@localhost:5432/trade_erp?schema=public"

# Encryption - AES-256-GCM key for PlatformSyncConfig.credentials (32字节hex = 64个hex字符)
# 生成方式: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-string-here-change-in-production"

# NextAuth (optional - for authentication)
# NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
# NEXTAUTH_URL="http://localhost:3001"

# Development - Port 3001 (avoid conflict with production container)
PORT=3001
TEST_BASE_URL="http://localhost:3001"

# Production - Port 3000 (Docker container)
# PROD_PORT=3000
# PROD_URL="http://localhost:3000"
